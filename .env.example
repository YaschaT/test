# Copy this file to .env and fill in values only if you want Google Cloud TTS.
# The app works perfectly without any of this — it falls back to your browser's
# built-in Japanese voice automatically.

# Backend proxy port (the Vite dev server proxies /api requests here).
SERVER_PORT=5174

# Set to "true" to attempt Google Cloud TTS. Leave "false" (or unset) to stay on browser TTS only.
GOOGLE_CLOUD_TTS_ENABLED=false

# Required only if GOOGLE_CLOUD_TTS_ENABLED=true.
GOOGLE_CLOUD_PROJECT_ID=
# Path to your service account JSON key file, e.g. ./server/credentials/tts-service-account.json
# Never commit this file — see server/credentials/.gitignore.
GOOGLE_APPLICATION_CREDENTIALS=

GOOGLE_CLOUD_TTS_LANGUAGE_CODE=ja-JP
# Leave blank to let Google pick a default voice for the language code above.
GOOGLE_CLOUD_TTS_VOICE_NAME=

# Optional accounts (sign up / log in, progress synced across devices), backed by Supabase.
# Without these, the app works fully in guest/local mode — the account feature just shows
# "Accounts are almost ready" instead of failing. Get these from your Supabase project's
# Settings > API page. VITE_-prefixed vars are safe to expose client-side (the anon key is
# public by design; row-level security policies protect the actual data).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
